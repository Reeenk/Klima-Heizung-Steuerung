Es müssen die Platzhalter Sensoren durch deine Sensoren ersetzt werden.


alias: Klima Master V22
description: ""
triggers:
  - trigger: time_pattern
    minutes: /5
  - trigger: state
    entity_id: sensor.adsfadf_ladezustand	# Ladezustand der Speicher  
  - trigger: state
    entity_id: input_boolean.klima_automation	# Schalter für die Automation 
    to: "off"
    id: hauptschalter
actions:
  - variables:
      akt_soc: >-
        {{ states('sensor.adsfadf_ladezustand') | float(10)	# Ladezustand der Speicher
        }}
      target_mode: >-
        {{ 'heat' if (states('sensor.openweathermap_temperature') | float(15))	# Sensor für die Außentemperatur
        <= 18.0 else 'cool' }}
      aus_soc: >-
        {% set berechnet = states('sensor.empfohlener_batterie_soc_limit') |	# Der Sensor für die Berechnung des SOC
        float(90) %} {% set manuell =
        states('input_number.klima_akku_entnehmen') | float(95) %} {# Wir nehmen	# Hier den manuellen Wert für die SOC
        den kleinsten der beiden Werte, aber mindestens 30 #} {{ [ [berechnet,
        manuell] | min, 30 ] | max }}
      reservation: >-
        {% set month = now().month %} {% set threshold = 80 if month in [10, 11,
        12, 1, 2, 3] else 60 %} {% set soc =
        states('sensor.byd_battery_box_premium_hv_ladezustand') | float(0) %}	# Ladezustand der Speicher

        {% if soc < 55 %}
          1500				
        {% elif soc < 80 %}
           900
        {% else %}
           0
        {% endif %}
  - choose:
      - conditions:
          - condition: state
            entity_id: input_boolean.klima_automation	# Schalter für die Automation 
            state: "on"
          - condition: template
            value_template: "{{ states('sensor.pv_anlagen') | float(0) > 1500 }}"
          - condition: template
            value_template: >-
              {{ (states('sensor.pv_uberschuss_real') | float(0) - reservation)		# Überschuss Sensor
              >= 800 }}									# Muss großer wie 800 Watt sein
          - condition: template
            value_template: "{{ akt_soc >= aus_soc }}"
          - condition: time
            after: "06:30:00"
        sequence:
          - repeat:
              for_each:
                - climate: climate.klima_Klimagerät				# Sensor fürs Klimagerät
                  wunsch: input_number.Temperatur_temp				# Temperatur Sensor von Klimagerät
                  sensor: sensor.Externer Temperatur_temperatur			# Externer Temperatur Sensor für den Raum
                - climate: climate.klima_Klimagerät
                  wunsch: input_number.Temperatur_temp
                  sensor: sensor.Externer Temperatur
                - climate: climate.klima_Klimagerät
                  wunsch: input_number.Temperatur_temp
                  sensor: sensor.Externer Temperatur
                - climate: climate.klima_Klimagerät
                  wunsch: input_number.Temperatur_temp
                  sensor: sensor.Externer Temperatur
              sequence:
                - condition: template
                  value_template: >
                    {% set soll_raw = states(repeat.item.wunsch) | float(22) %}
                    {% set ist = states(repeat.item.sensor) | float(soll_raw) %}
                    {% set current_mode = state_attr(repeat.item.climate,
                    'hvac_mode') %} {% set current_temp =
                    state_attr(repeat.item.climate, 'temperature') | float(0) %}
                    {% set neu_temp = (soll_raw - 2 if target_mode == 'heat' and
                    ist >= soll_raw else (soll_raw + 1 if target_mode == 'cool'
                    and ist <= soll_raw else soll_raw)) %} {{ current_mode !=
                    target_mode or current_temp != neu_temp }}
                - action: climate.set_hvac_mode
                  data:
                    hvac_mode: "{{ target_mode }}"
                  target:
                    entity_id: "{{ repeat.item.climate }}"
                - action: climate.set_temperature
                  target:
                    entity_id: "{{ repeat.item.climate }}"
                  data:
                    temperature: >
                      {% set soll = states(repeat.item.wunsch) | float(22) %} {%
                      set ist = states(repeat.item.sensor) | float(soll) %} {%
                      if target_mode == 'heat' %}
                        {{ soll - 1 if ist >= soll else soll }}
                      {% elif target_mode == 'cool' %}
                        {{ soll + 1 if ist <= soll else soll }}
                      {% else %}
                        {{ soll }}
                      {% endif %}
          - action: input_boolean.turn_on
            target:
              entity_id:
                - input_boolean.klima_status
                - input_boolean.klima_auto
          - action: input_boolean.turn_on
            target:
              entity_id: >-
                {{ 'input_boolean.klima_heizen' if target_mode == 'heat' else
                'input_boolean.klima_kuhlen' }}
          - action: input_boolean.turn_off
            target:
              entity_id: >-
                {{ 'input_boolean.klima_kuhlen' if target_mode == 'heat' else
                'input_boolean.klima_heizen' }}
          - if:
              - condition: state
                entity_id: switch.heizung		# Schalter für Heizung
                state: "on"
            then:
              - action: switch.turn_off
                target:
                  entity_id: switch.heizung		# Schalter für Heizung
      - conditions:
          - or:
              - condition: trigger
                id: hauptschalter
              - condition: template
                value_template: "{{ akt_soc < aus_soc }}"
        sequence:
          - action: climate.turn_off
            target:
              entity_id:
                - climate.klima_Klimagerät			# Sensor fürs Klimagerät
                - climate.klima_Klimagerät
                - climate.klima_Klimagerät
                - climate.klima_Klimagerät
          - action: input_boolean.turn_off
            target:
              entity_id:
                - input_boolean.klima_status
                - input_boolean.klima_heizen
                - input_boolean.klima_kuhlen
                - input_boolean.klima_auto
mode: restart
